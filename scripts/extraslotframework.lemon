global u8 extra_slot_priority

function u8 count(u8 x)
{
	x += 1
	extra_slot_priority = x
	u8 result = base.count(x)
	if (result == 0)
	{
		extra_slot_priority |= 0x80
		return x
	}
	else
	{
		return result
	}	
}

global bool is_mighty
global u8 save_slot_data

// TODO: Need to make the entire act select work.
// NOTE: 0xffffe6ac is the start of the memory where the normal save data gets loaded. Each save slot is 10 bytes.

// Helper function
function u32 getEmptyBuffer(u32 bytes)
{
	// Find an empty buffer in shared memory to store data.
	// 0x820000 will almost certainly be empty, but just to be safe.
	u32 buffer_address = 0x820000
	u32 data = 0
	u8 i = 0
	while (i < bytes)
	{
		data = u32[buffer_address + i]
		i += 4
		if (data != 0)
		{
			buffer_address += i
			i = 0
		}
	}
	return buffer_address
}

function void Game.returnToMainMenu()
{
	// TODO: This does not really work in v24 of Sonic 3 AIR, we need a later version where the pause menu is moddable.
	is_mighty = 0
	base.Game.returnToMainMenu()
}

function void DataSelect.setup()
{
	is_mighty = 0
	count(0)
	u32 buffer_address = getEmptyBuffer(1)
	// The save data payload is only 1 byte; each save file gets 1 bit which is on/off if it's a mighty file.
	System.loadPersistentData(buffer_address, (CHAR_KEY + "_save_data"), 1)
	save_slot_data = u8[buffer_address]
	// Clear shared memory buffer.
	u8[buffer_address] = 0
	base.DataSelect.setup()
}

// dataselect_slot.init()
//# address-hook(0x00d39e) end(0x00d426)
function void fn00d39e()
{
	base.fn00d39e()
	// If this slot is a mighty file...
	if (save_slot_data & (1 << objA0.flags2e))
	{
		u8 max_characters = Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS) ? 4 : 3
		// Adjust the save slot's character value.
		u8[A0 + 0x35] =  max_characters + 2 * (extra_slot_priority & 0x7f) - (u8[A0 + 0x35] & 1)
	}
}

// dataselect_slot.update()
//# address-hook(0x00d42c) end(0x00d69a)
function void fn00d42c()
{
	// This "filler byte" is apparently unused in the original game. Sonic 3 AIR uses it to store a random number seed.
	u8 filler_byte_temp = u8[u32[A0 + 0x30] + 0x01]
	u8 extra_characters = ((Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS)) ? 4 : 3) + 2 * (extra_slot_priority & 0x7f)
	base.fn00d42c()
	// If the filler byte has changed, then a new game has been initialized. If an ES character was selected...
	if (filler_byte_temp != u8[A1 + 0x01] && (u8[A0 + 0x35] == extra_characters || u8[A0 + 0x35] == (extra_characters - 1)))
	{
		// The game cannot handle a character value above 3 (or maybe 4), so make sure it's in bounds.
		// This is 0 if the ES character is paired with Tails, and 1 if not.
		levelselect.characters = ((extra_characters & 1) ^ (u8[A0 + 0x35] & 1))
		// Also adjust the saved character value. We don't want to actually store an irregular value in the save file.
		u8[A1 + 0x02] = (u8[A1 + 0x02] & 0x0f) | (levelselect.characters << 4)
		if (CHARACTER_BASE == 3)
			levelselect.characters = 4 - levelselect.characters
		SaveGameSlot()
	}

	// Also, cap this value to simplify the logic for drawing the character portrait and icons.
	if (objA0.animation.sprite > 8)
		objA0.animation.sprite = 8
}

// NOTE: This function is not a bool. Even though its signature says "bool", it can return 0, 1, or 2.
function bool fn00d458()
{
	// NOTE: If you want to allow Tails and Knuckles to select any stage, this is the function that needs to be modified.
	u8 result = base.fn00d458()
	u8 extra_characters = (Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS) ? 4 : 3) + (extra_slot_priority & 0x7f) * 2
	u32 slot_index = (A1 - 0xffffe6ac) / 0x0a
	// If this is true, we're starting a game on a new save file as an ES character.
	if ((result == 1) && ((u8[A0 + 0x35] == extra_characters) || (u8[A0 + 0x35] == extra_characters - 1)) && (control.pad1.pressed & (CONTROL_START | CONTROL_A)))
	{
		// We need to mark that this file is an ES character in the persistent data.
		save_slot_data |= 1 << slot_index
		u32 buffer_address = getEmptyBuffer(1)
		u8[buffer_address] = save_slot_data
		System.savePersistentData(buffer_address, (CHAR_KEY + "_save_data"), 1)
		// Clear the buffer.
		u8[buffer_address] = 0
		// Mark that are playing as mighty.
		is_mighty = 1
	}
	// If this is true, we are starting a game on an existing save file.
	else if (result == 0)
	{
		// Check extra save slot data to see if this is a Mighty save.
		if (save_slot_data & (1 << slot_index))
		{
			// If so, set the save slot's character value to be in-bounds, and mark that we are playing as mighty.
			levelselect.characters = ((extra_characters & 1) ^ (u8[A0 + 0x35] & 1))
			if (CHARACTER_BASE == 3)
				levelselect.characters = 4 - levelselect.characters
			is_mighty = 1
		}
	}
	return result
}

//# address-hook(0x00d6d0) end(0x00d70a)
function void fn00d6d0()
{
	// Have only the bottom priority mod handle this.
	if (!(extra_slot_priority & 0x80))
	{
		base.fn00d6d0()
		return
	}
	// Character Selection: Allow for selecting higher than the normal maximum character.
	u8 max_characters = (Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS) ? 4 : 3)
	// D0.u16 is used as the character index for this function.
	if (D0.u16 >= max_characters)
	{
		u16 d0_temp = D0.u16
		D0.u16 = 1
		base.fn00d6d0()
		s16 diff = D0.u16 - 1
		D0.u16 = d0_temp + diff
		if (D0.u16 > (max_characters + 2 * (extra_slot_priority & 0x7f)))
			D0.u16 = 0
	}
	else if (D0.u16 == 0)
	{
		base.fn00d6d0()
		if (D0.u16 == max_characters)
			D0.u16 += 2 * (extra_slot_priority & 0x7f)
	}
	else
	{
		base.fn00d6d0()
	}
}

//# address-hook(0x00d30c) end(0x00d39a)
function void fn00d30c()
{
	base.fn00d30c()
	u8 extra_characters = ((Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS)) ? 4 : 3) + 2 * (extra_slot_priority & 0x7f)
	if ((dataselect.slot_selected == 0) && ((levelselect.characters == extra_characters) || (levelselect.characters == (extra_characters - 1))))
	{
		levelselect.characters = ((extra_characters & 1) ^ (dataselect.nosave_characters & 1))
		if (CHARACTER_BASE == 3)
			levelselect.characters = 4 - levelselect.characters
		is_mighty = 1
	}

	if (objA0.animation.sprite > 8)
		objA0.animation.sprite = 8
}

function bool Standalone.onDrawVdpSpriteCompound(s16 px, s16 py, u8 size, u16 index, u16 renderQueue, u8 spriteCounter)
{
	u8 max_characters = (Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS) ? 4 : 3)
	u8 extra_chars = (Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS) ? 4 : 3) + (extra_slot_priority & 0x7f) * 2

	if ((objA0.update_address != 0x00d30c && objA0.update_address != 0x00d42c))
	{
		return base.Standalone.onDrawVdpSpriteCompound(px, py, size, index, renderQueue, spriteCounter)
	}

	u8 selected_char = 0
	if (objA0.update_address == 0x00d42c)
		selected_char = u8[A0 + 0x35]
	else
		selected_char = dataselect.nosave_characters
	
	if ((selected_char != extra_chars) && (selected_char != (extra_chars - 1)))
	{
		return base.Standalone.onDrawVdpSpriteCompound(px, py, size, index, renderQueue, spriteCounter)
	}
	if (index == 0xa342)
	{
		bool with_tails = (selected_char == extra_chars)
		if (with_tails)
		{
			// Draw Tails. This is how Sonic 3 Air does it for Knuckles + tails.
			u16 attributes = sprite_attribute.PRIORITY | sprite_attribute.PALETTE.LINE1 | sprite_attribute.FLIP_X
			Renderer.drawVdpSprite(px+28, py+30, 0x00, attributes | 0x031d, renderQueue)
			Renderer.drawVdpSprite(px+20, py+38, 0x0d, attributes | 0x031e, renderQueue)
			Renderer.drawVdpSprite(px+28, py+54, 0x0d, attributes | 0x0326, renderQueue)
			Renderer.drawVdpSprite(px+20, py+62, 0x00, attributes | 0x032e, renderQueue)
			px -= 8
		}
		renderQueue++
		// Draw mighty's portrait.
		SpriteHandle spr1 = Renderer.addSpriteHandle("charselect_mighty", (with_tails ? px+42 : px+16), py+35, renderQueue)
		spr1.setFlipX(with_tails)
		// If this is not a new save slot...
		if (!(u8[u32[A0 + 0x30]] & 0x80) && (objA0.update_address == 0x00d42c))
		{
			// Draw the life and continue sprites.
			SpriteHandle spr2 = Renderer.addSpriteHandle("lives_icon_mighty", px+12, py+80, renderQueue)
			SpriteHandle spr3 = Renderer.addSpriteHandle("hud_char_colon", px+28, py+80, renderQueue)
			SpriteHandle spr4 = Renderer.addSpriteHandle("continue_icon_mighty_wait_0x00", px+20, py+108, renderQueue)
			SpriteHandle spr5 = Renderer.addSpriteHandle("hud_char_colon", px+28, py+104, renderQueue)
		}
		return true
	}
	else if (index == 0xa34e)
	{
		return true
	}
	return base.Standalone.onDrawVdpSpriteCompound(px, py, size, index, renderQueue, spriteCounter)
}

function void fn001506()
{
	if (D1 == 2 && D2 == 4)
	{
		if (u8[A3 + 0x35] > (Game.isSecretUnlocked(SECRET_KNUX_AND_TAILS) ? 4 : 3))
		{
			// Prevent the life and continue icons from being drawn on this save slot object.
			// TODO: I'm not sure this is a good way to do this.
			return
		}
	}
	base.fn001506()
}

//# address-hook(0x00d8c4) end(0x00d90c)
function void fn00d8c4()
{
	u16 data_temp = u16[A1]
	base.fn00d8c4()
	// If this is true, the save slot data was cleared.
	if (u16[A1] == 0x8000 && data_temp != 0x8000)
	{
		// Clear the bit marking this is a mighty save slot from persistentdata.
		// TODO: If the player turns the mod off, then clears a save slot, it will still be marked as a mighty save.
		u32 slot_index = (A1 - 0xffffe6ac) / 0x0a
		u32 buffer_address = getEmptyBuffer(1)
		System.loadPersistentData(buffer_address, (CHAR_KEY + "_save_data"), 1)
		u8[buffer_address] &= ~(1 << slot_index)
		System.savePersistentData(buffer_address, (CHAR_KEY + "_save_data"), 1)
		u8[buffer_address] = 0
	}
}

///////////////////////////////
///		 DOCUMENTATION		///
///////////////////////////////

function void DataSelect.update()
{
	// This function has bizzare behavior. Any code written before the base call will work fine,
	// but the base function *does not return* until you exit the Data Select screen.
	base.DataSelect.update()
	// Additionally, if you exit to the main menu instead of selecting a save file, any code written
	// after the base call just doesn't get run at all.
}

//# address-hook(0x00d1fa) end(0x00d30a)
function void fn00d1fa()
{
	base.fn00d1fa()
}

/* Some Notable Functions:
	fn00d1fa() - Checks for LEFT+RIGHT inputs to scroll between saves, checks for "BACK" to exit menu, and checks for "Y".
	fn00d42c() - Checks for ACCEPT input when hovering over an empty save, and begins it.
	fn00d458() - Checks for UP+DOWN inputs to change zones.
	fn00d6d0() - Checks for UP+DOWN inputs to change characters.
*/