//////////////////////////
///     ANIMATIONS     ///
//////////////////////////

// Helper function
function void updateWinPose()
{
    if (char.state == char.state.WIN_POSE)
    {
        // Advance the custom win pose animation.
        mighty_wp_timer += 1
        // Advance to a new animation frame when the timer reaches the values in the list.
        if (mighty_wp_timer >= WP_TIMES[mighty_wp_frame])
            mighty_wp_frame = min(mighty_wp_frame + 1, 9)
        // Loop timer within animation length (?)
        if (mighty_wp_timer >= WP_TIMES[9] + WP_TIMES[0])
            mighty_wp_timer = WP_TIMES[8]
    }
	else
	{
        // Reset when not in win-pose.
        mighty_wp_timer = 0
        mighty_wp_frame = 0
	}
}

// Helper function
function void updateSuperBallAnim()
{
    if (super_ball_state)
    {
        u8 df = 6
        if (!(char.flags & char.flag.IN_AIR))
            df += min(max((abs(char.groundspeed)) >> 9, 1) - 1, 8)
        else
            df += min(max((hypot(char.velocity.x, char.velocity.y)) >> 9, 1) - 1, 8)
        super_ball_animation_state += df
    } 

    super_ball_animation_state &= 0x3f
}

// Helper function
function bool isInIdleAnimation()
{
    return (char.animation.sprite == 0xd9 || (char.animation.sprite >= 0xad && char.animation.sprite <= 0xb3) || (char.animation.sprite >= 0xbb && char.animation.sprite <= 0xc0))
}

// Helper function
function void updateIdleAnimation()
{
    if (isInIdleAnimation())
    {
        idle_animation += 1
    }
    else
    {
        idle_animation = 0
        idle_sprite = 0
    }
        
    if (idle_animation >= idle_animation_times[idle_sprite])
    {
        idle_animation = 0
        idle_sprite += 1
    }
    if (idle_sprite >= idle_animation_sprites.length())
    {
        idle_sprite = 3
    }
    idle_sprite %= (idle_animation_sprites.length())
}

//# address-hook(0x012600) end(0x01286c)
//# translated(0x012a2a) end(0x012a6e)
function void UpdateSonicAnimation()
{
    // Force the game to use Sonic's base spritesheet even during the super form.
    if (isMighty() && super.palettefx.state == 0xff)
    {
        u8 super_temp = super.active
        super.active = 0
        base.UpdateSonicAnimation()
        super.active = super_temp
    }
    else
    {
        base.UpdateSonicAnimation()
    }
}