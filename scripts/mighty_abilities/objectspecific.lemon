global bool break_wall

function void fn021758()
{
    if (is_ES && (D6 & 0x10000) && !(u8[0xffffb037] & 0x40) && super_ball_state)
    {
        u8[0xffffb037] |= 0x40
        base.fn021758()
        u8[0xffffb037] &= ~0x40
        return
    }

    base.fn021758()
}

//# address-hook(0x021568) end(0x021690)
function void fn021568()
{
    if (is_ES && !super.active && super_ball_state && !(objA0.flags2a & object.flag.P1_PUSHING))
    {
        break_wall = true
        base.fn021568()
        super.active = 0
        break_wall = false
        return
    }

    base.fn021568()
}

function void fn01e006()
{
    if (break_wall && A1 == 0xffffb000)
    {
        u16 position_temp = objA1.position.y.u16
        base.fn01e006()
        if (objA1.position.y.u16 != position_temp)
        {
            objA1.position.y.u16 = position_temp
            super.active = 1
        }
        return
    }
    
    base.fn01e006()
}

//# address-hook(0x01e042)
function void fn01e042()
{
    if (break_wall && A1 == 0xffffb000)
    {
        u16 position_temp = objA1.position.x.u16
        base.fn01e042()
        if (objA1.position.x.u16 != position_temp)
        {
            objA1.position.x.u16 = position_temp
