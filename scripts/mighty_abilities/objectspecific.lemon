//# address-hook(0x031226) end(0x031458)
function void fn031226()
{
    // HCZ conveyor belt
    if (!isMightyA1() || u8[A2] != 0 || !hammer_drop_state)
    {
        base.fn031226()
        return
    }

    // Replicate all the conditions for grabbing onto the conveyor belt.
    if (objA1.position.x.u16 >= u16[A0 + 0x40] && objA1.position.x.u16 < u16[A0 + 0x42])
    {
        bool upperBelt = (u16[A1 + 0x1c] == 1)
		u16 py = objA0.position.y.u16 + (upperBelt ? -0x14 : 0x14)

        if (objA1.position.y.u16 > py && objA1.position.y.u16 <= py + 0x10)
		{
			if (debug_mode.state == 0 && u8[A1 + 0x05] < base_state.HURT && u8[A1 + 0x2e] == 0)
            {
                objA1.position.y.u16 += 0x40
                base.fn031226()
                objA1.position.y.u16 -= 0x40
                return
            }
        }
    }

    base.fn031226()
}

// HCZ corkscrewslide

//# address-hook(0x039102) end(0x039206)
function void fn039102()
{
    u8 control_flags_temp = u8[A1 + 0x2e]
    base.fn039102()
    if (isMightyA1() && (control_flags_temp == 0) && (u8[A1 + 0x2e] != 0))
        keep_super_ball = true
}

//# address-hook(0x039208) end(0x03925a)
function void fn039208()
{
    if (!isMightyA1())
    {
        base.fn039208()
        return
    }
    base.fn039208()
    if (super_ball_state && abs(s16[A1 + 0x1c]) < 0x800)
    {
        s16[A1 + 0x1c] = (s16[0x1c] > 0) ? min(s16[A1 + 0x1c] + 0x20, 0xa00) : max(s16[A1 + 0x1c] - 0x20, -0xa00)
    }
}

//# address-hook(0x0390c2) end(0x0390f0)
function void fn0390c2()
{
    u8 control_flags_temp = u8[A1 + 0x2e]
    base.fn0390c2()
    if (isMightyA1() && control_flags_temp != 0 && u8[A1 + 0x2e] == 0)
        keep_super_ball = false
}

