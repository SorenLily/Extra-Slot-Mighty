    if (isMightyA1() && control_flags_temp != 0 && u8[A1 + 0x2e] == 0)
        keep_super_ball = false
}

//# address-hook(0x028de4) end(0x028e70)
function void SpinLauncher.Update()
{
    // LBZ Spin Launcher
    s16 velocity_temp = s16[0xffffb01a]
    u8 flags_temp = objA0.flags2a & object.flag.P1_ON_OBJECT
    base.SpinLauncher.Update()
    if (is_ES && flags_temp == (objA0.flags2a & object.flag.P1_ON_OBJECT) && (velocity_temp > 0) && s16[0xffffb01a] != velocity_temp)
        s16[0xffffb01a] = velocity_temp
}

//# address-hook(0x08dc6e) end(0x08dcc4)
function void fn08dc6e()
{
    // MHZ Mushmeanie collision logic
    s16 velocity_temp.x = s16[0xffffb018]
    s16 velocity_temp.y = s16[0xffffb01a]
    s16 groundspeed_temp = s16[0xffffb01c]
    base.fn08dc6e()
    if (isMightyA1() && super_ball_state && (objA1.velocity.x != velocity_temp.x || objA1.velocity.y != velocity_temp.y))
    {
        objA1.velocity.x = velocity_temp.x
        objA1.velocity.y = velocity_temp.y
        objA1.groundspeed = groundspeed_temp
    }
}

//# address-hook(0x03ec66) end(0x03ed08)
function void fn03ec66()
{
    // MHZ Sticky Vine (pull the player and check for release)
    if (isMightyA1() && super_ball_state)
    {
        if (u8[A0 + 0x3d] == 0)
        {
            u8[A0 + 0x3d] = 1
            u8[A0 + 0x3e] = 0x10
        }
        s16 speed_temp = (objA1.flags2a & char.flag.IN_AIR) ? objA1.velocity.x : objA1.groundspeed
        base.fn03ec66()
        if (objA1.flags2a & char.flag.IN_AIR)
            objA1.velocity.x = speed_temp
        else
            objA1.groundspeed = speed_temp

        return
    }
    base.fn03ec66()
}

global bool no_recurse

//# address-hook(0x03c636) end(0x03c6b6)
function void fn03c636()
{
    // FBZ Parachute Bomb Door
    if (no_recurse)
    {
        base.fn03c636()
        return
    }

    s16 velocity_temp = s16[0xffffb01a]
    u8 flags_temp = objA0.flags2a & object.flag.P1_ON_OBJECT
    u32 other_address = 0xffff0000 + u16[A0 + 0x3c]
    base.fn03c636()
    if (is_ES && hammer_crash && (objA0.flags2a & object.flag.P1_ON_OBJECT) && !(flags_temp & object.flag.P1_ON_OBJECT))
    {
        u8[other_address + 0x40] = 0
        s16[0xffffb01a] = velocity_temp
        store_bounce = 0
        no_recurse = true
        fn03c636()
        no_recurse = false
    }
}

//# address-hook(0x03fd4e) end(0x03fe42)
function void fn03fd4e()
{
    // SOZ sandflow
    u8 on_object_temp = objA1.flags2a & char.flag.ON_OBJECT
    base.fn03fd4e()
    // If mighty "landed" on the sandflow...
    if (isMightyA1() && (objA1.flags2a & char.flag.ON_OBJECT) && !on_object_temp)
    {
        // Stop the hammer drop.
        hammer_drop_state = 0
        hammer_crash = 0
    }
}